          "name": "Get Package Download Totals",
          "request": {
            "name": "Get Package Download Totals",
            "description": {
              "content": "Returns the total number of downloads for one or more R packages over the specified time period from the RStudio CRAN mirror.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "downloads",
                "total",
                ":period",
                ":packages"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "period",
                  "description": "(Required) Time period for download stats. Use last-day, last-week, last-month, grand-total, or a date range like 2023-01-01:2023-12-31."
                },
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "packages",
                  "description": "(Required) Package name or comma-separated list of package names."
                }
              ]
